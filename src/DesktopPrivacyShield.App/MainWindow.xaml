<Window x:Class="DesktopPrivacyShield.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopPrivacyShield"
        Width="980"
        Height="640"
        MinWidth="900"
        MinHeight="580"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <Border Width="56" Height="56" CornerRadius="14" Background="#1A18354A" BorderBrush="#33476A84" BorderThickness="1" HorizontalAlignment="Left">
                    <Image Width="40" Height="40" Source="pack://application:,,,/Resources/logo.png" Stretch="Uniform" />
                </Border>
                <TextBlock Margin="0,18,0,0" FontSize="34" FontWeight="SemiBold" Text="Desktop Privacy Shield" />
                <TextBlock Margin="0,10,0,0"
                           MaxWidth="620"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="15"
                           Text="为需要持续保持当前桌面会话的任务提供隐私遮罩。离开工位时，遮住真实桌面；返回时，用本地密码恢复显示。"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Border Style="{StaticResource CardBorderStyle}" Padding="14,10" Background="#5518D2FF">
                    <TextBlock Text="{Binding StatusAccent}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Padding="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前状态" />
                        <TextBlock Margin="0,8,0,0" FontSize="26" FontWeight="SemiBold" Text="{Binding StatusTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   Text="{Binding StatusDescription}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="#99132738" Padding="18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="解锁方式" />
                                <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Text="本地密码验证" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="使用 PBKDF2 哈希保存密码，不存明文。" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Background="#99132738" Padding="18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="快速操作" />
                                <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Text="Ctrl + Alt + L" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="托盘菜单、热键和空闲触发都可以进入遮罩模式。" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Padding="18" Background="#88112939">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Width="64" Height="64" Source="pack://application:,,,/Resources/logo.png" Stretch="Uniform" />
                            <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="桌面任务继续运行" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="这个工具不会切换到系统登录界面，适合需要继续在当前桌面会话中运行的任务。"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}" Padding="24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="立即执行" />
                        <TextBlock Margin="0,10,0,18"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="进入遮罩模式后，主显示器会显示密码输入界面，其余显示器只显示遮罩。"
                                   TextWrapping="Wrap" />
                        <Button Height="44" Content="立即遮罩" Command="{Binding LockCommand}" />
                        <Button Height="44" Margin="0,12,0,0" Content="打开设置" Style="{StaticResource SecondaryButtonStyle}" Click="OnOpenSettingsClicked" />
                    </StackPanel>
                </Border>

                <Border Margin="0,20,0,0" Style="{StaticResource CardBorderStyle}" Padding="24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="安全边界" />
                        <TextBlock Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 不是系统级安全锁屏" />
                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 不拦截 Ctrl + Alt + Del" />
                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 不禁用任务管理器" />
                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 适合桌面隐私遮挡，不替代 Win + L" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
