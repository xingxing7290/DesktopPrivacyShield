<Window x:Class="DesktopPrivacyShield.App.Views.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Black"
        AllowsTransparency="False">
    <Grid Background="#050505">
        <Border x:Name="ContentPanel"
                Width="420"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#151515"
                BorderBrush="#2C2C2C"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="White" Text="AI Task Running" />
                <TextBlock Margin="0,10,0,0" Foreground="#BBBBBB" Text="当前桌面已被临时遮挡" />
                <TextBlock Margin="0,4,0,18" Foreground="#BBBBBB" Text="请输入密码解锁" />
                <TextBlock x:Name="ClockText" Margin="0,0,0,18" FontSize="18" Foreground="#D7D7D7" />
                <TextBlock Margin="0,0,0,12"
                           Foreground="#9CC3FF"
                           Text="{Binding OverlayMessage}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ShowMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <PasswordBox x:Name="PasswordInput" Height="38" Margin="0,0,0,12" PasswordChar="●" />
                <Button Width="110" Height="36" HorizontalAlignment="Left" Content="解锁" Click="OnUnlockClicked" />
                <TextBlock Margin="0,14,0,0" Foreground="#E67E22" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
