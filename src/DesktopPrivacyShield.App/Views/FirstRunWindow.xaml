<Window x:Class="DesktopPrivacyShield.App.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="首次设置"
        Width="560"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Border Style="{StaticResource CardBorderStyle}" Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="72" Height="72" Background="#1A18354A" CornerRadius="18" BorderBrush="#33476A84" BorderThickness="1" HorizontalAlignment="Left">
                        <Image Width="52" Height="52" Source="pack://application:,,,/Resources/logo.png" Stretch="Uniform" />
                    </Border>
                    <TextBlock Margin="0,18,0,0" FontSize="28" FontWeight="SemiBold" Text="设置本地解锁密码" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14"
                               Text="首次启动需要创建一个本地密码。程序只保存 PBKDF2 哈希结果，不保存明文密码。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="输入密码" />
                    <PasswordBox x:Name="PasswordInput" Height="42" Margin="0,8,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="确认密码" />
                    <PasswordBox x:Name="ConfirmInput" Height="42" Margin="0,8,0,0" />
                </StackPanel>

                <Border Grid.Row="5" Margin="0,18,0,0" Background="#80111F2C" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" FontSize="16" Text="建议" />
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 使用长度更高、便于自己记忆的密码" />
                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 如果忘记密码，需要删除本地配置文件后重新初始化" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="6">
                    <TextBlock Foreground="{StaticResource DangerBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
                    <Button Width="140"
                            Height="42"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Right"
                            Content="保存并继续"
                            Click="OnSaveClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
