<Window x:Class="DesktopPrivacyShield.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="540"
        Height="620"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Desktop Privacy Shield" />
            <CheckBox Grid.Row="1" Margin="0,18,0,0" Content="开机自启" IsChecked="{Binding StartWithWindows}" />
            <CheckBox Grid.Row="2" Margin="0,10,0,0" Content="启动后立即遮罩" IsChecked="{Binding StartLocked}" />
            <CheckBox Grid.Row="3" Margin="0,10,0,0" Content="启用空闲自动遮罩" IsChecked="{Binding IdleLockEnabled}" />

            <StackPanel Grid.Row="4" Margin="0,10,0,0">
                <TextBlock Text="空闲分钟数" />
                <TextBox Width="120" Margin="0,6,0,0" Text="{Binding IdleLockMinutes}" />
            </StackPanel>

            <CheckBox Grid.Row="5" Margin="0,14,0,0" Content="启用 Ctrl+Alt+L 快捷键" IsChecked="{Binding HotkeyEnabled}" />
            <CheckBox Grid.Row="6" Margin="0,10,0,0" Content="覆盖所有显示器" IsChecked="{Binding CoverAllMonitors}" />
            <CheckBox Grid.Row="7" Margin="0,10,0,0" Content="显示时钟" IsChecked="{Binding ShowClock}" />
            <CheckBox Grid.Row="8" Margin="0,10,0,0" Content="显示提示文案" IsChecked="{Binding ShowMessage}" />

            <StackPanel Grid.Row="9" Margin="0,12,0,0">
                <TextBlock Text="遮罩文案" />
                <TextBox Margin="0,6,0,0" Height="72" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Message}" />
            </StackPanel>

            <TextBlock Grid.Row="10" Margin="0,22,0,8" FontSize="18" FontWeight="SemiBold" Text="修改密码" />
            <PasswordBox x:Name="CurrentPasswordInput" Grid.Row="11" Height="34" />
            <PasswordBox x:Name="NewPasswordInput" Grid.Row="12" Margin="0,10,0,0" Height="34" />
            <PasswordBox x:Name="ConfirmPasswordInput" Grid.Row="13" Margin="0,10,0,0" Height="34" VerticalAlignment="Top" />

            <StackPanel Grid.Row="14" Margin="0,20,0,0">
                <TextBlock Foreground="#2E7D32" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                <Button Width="120" Height="36" Margin="0,12,0,0" HorizontalAlignment="Right" Content="保存设置" Click="OnSaveClicked" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
