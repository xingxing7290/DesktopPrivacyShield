<Window x:Class="DesktopPrivacyShield.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="900"
        Height="760"
        MinWidth="820"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="56" Height="56" Background="#1A18354A" CornerRadius="14" BorderBrush="#33476A84" BorderThickness="1">
                    <Image Width="40" Height="40" Source="pack://application:,,,/Resources/logo.png" Stretch="Uniform" />
                </Border>
                <StackPanel Grid.Column="2">
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="应用设置" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="调整遮罩行为、快捷键、开机自启和解锁密码。"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="运行行为" />
                        <CheckBox Content="开机自启" IsChecked="{Binding StartWithWindows}" />
                        <CheckBox Content="启动后立即遮罩" IsChecked="{Binding StartLocked}" />
                        <CheckBox Content="启用空闲自动遮罩" IsChecked="{Binding IdleLockEnabled}" />

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="空闲分钟数" />
                            <TextBox Width="140" Margin="0,8,0,0" Text="{Binding IdleLockMinutes}" />
                        </StackPanel>

                        <CheckBox Margin="0,18,0,0" Content="启用 Ctrl + Alt + L 快捷键" IsChecked="{Binding HotkeyEnabled}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="遮罩外观" />
                        <CheckBox Content="覆盖所有显示器" IsChecked="{Binding CoverAllMonitors}" />
                        <CheckBox Content="显示时钟" IsChecked="{Binding ShowClock}" />
                        <CheckBox Content="显示提示文案" IsChecked="{Binding ShowMessage}" />

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="遮罩文案" />
                            <TextBox Margin="0,8,0,0"
                                     Height="96"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     Text="{Binding Message}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="修改密码" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="输入当前密码，并设置新的本地解锁密码。"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,18,0,0" Style="{StaticResource LabelTextStyle}" Text="当前密码" />
                        <PasswordBox x:Name="CurrentPasswordInput" Height="40" Margin="0,8,0,0" />

                        <TextBlock Margin="0,16,0,0" Style="{StaticResource LabelTextStyle}" Text="新密码" />
                        <PasswordBox x:Name="NewPasswordInput" Height="40" Margin="0,8,0,0" />

                        <TextBlock Margin="0,16,0,0" Style="{StaticResource LabelTextStyle}" Text="确认新密码" />
                        <PasswordBox x:Name="ConfirmPasswordInput" Height="40" Margin="0,8,0,0" />
                    </StackPanel>

                    <Border Grid.Column="2" Background="#80111F2C" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" FontSize="16" Text="提示" />
                            <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 修改密码后，新密码会立即生效" TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 系统锁屏账户密码和本程序密码彼此独立" TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="• 忘记本程序密码时，可删除本地配置文件重新初始化" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="6">
                <TextBlock Foreground="{StaticResource SuccessBrush}" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                <StackPanel Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="132" Height="42" Content="保存设置" Click="OnSaveClicked" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
