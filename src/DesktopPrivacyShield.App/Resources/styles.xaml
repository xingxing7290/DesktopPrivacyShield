<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Brush.Window">#08131D</Color>
    <Color x:Key="Brush.WindowAlt">#0D1C28</Color>
    <Color x:Key="Brush.Panel">#122432</Color>
    <Color x:Key="Brush.PanelRaised">#162C3D</Color>
    <Color x:Key="Brush.Border">#27485F</Color>
    <Color x:Key="Brush.TextPrimary">#F2F7FB</Color>
    <Color x:Key="Brush.TextSecondary">#9CB6CA</Color>
    <Color x:Key="Brush.TextMuted">#7390A6</Color>
    <Color x:Key="Brush.Accent">#27D2FF</Color>
    <Color x:Key="Brush.AccentStrong">#198CFF</Color>
    <Color x:Key="Brush.Success">#4ADE80</Color>
    <Color x:Key="Brush.Warning">#FFB649</Color>
    <Color x:Key="Brush.Danger">#FF6D7E</Color>

    <SolidColorBrush x:Key="WindowBrush" Color="{StaticResource Brush.Window}" />
    <SolidColorBrush x:Key="WindowAltBrush" Color="{StaticResource Brush.WindowAlt}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource Brush.Panel}" />
    <SolidColorBrush x:Key="PanelRaisedBrush" Color="{StaticResource Brush.PanelRaised}" />
    <SolidColorBrush x:Key="BorderBrushStrong" Color="{StaticResource Brush.Border}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource Brush.TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Brush.TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource Brush.TextMuted}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Brush.Accent}" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource Brush.AccentStrong}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Brush.Success}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Brush.Warning}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Brush.Danger}" />

    <LinearGradientBrush x:Key="WindowGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#08131D" Offset="0" />
        <GradientStop Color="#0B1724" Offset="0.45" />
        <GradientStop Color="#102335" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#27D2FF" Offset="0" />
        <GradientStop Color="#198CFF" Offset="1" />
    </LinearGradientBrush>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowGradientBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="Icon" Value="pack://application:,,,/Resources/app.ico" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#CC122432" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="LabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.95" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="#FF163041" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="#FF0F1F2B" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="#FF0F1F2B" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>
</ResourceDictionary>
